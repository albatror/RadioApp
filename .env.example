# Copy this file to .env and fill in the values
# .env is gitignored — never commit secrets

# Vite exposes variables prefixed with VITE_ to the client bundle.
# Do NOT prefix sensitive keys — they will be visible in the browser.

# Example: override the AzuraCast station API endpoint
# VITE_AZURACAST_API_URL=https://ethnafrika.org/api/nowplaying/ethnafrika

# Example: override the audio stream URL
# VITE_STREAM_URL=https://ethnafrika.org/listen/ethnafrika/radio.mp3
